# Backend Environment Variables
# Copy this to .env and fill in your values

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/mideast-tracker?retryWrites=true&w=majority

# Frontend URL for CORS (your Vercel deployment)
FRONTEND_URL=https://your-app.vercel.app

# Port (Render/Railway auto-assigns this)
PORT=4000

# NewsAPI.org — free tier, 100 req/day
# Get key at: https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# Twitter/X API v2 — for enhanced search (optional)
# Get at: https://developer.twitter.com
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# Sentinel Hub (optional, free registration)
# Get at: https://www.sentinel-hub.com/
SENTINEL_HUB_INSTANCE_ID=your_sentinel_hub_instance_id
